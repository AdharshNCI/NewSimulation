<Application 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:local="clr-namespace:FoundryCenter"   
    x:Class="FoundryCenter.App" 
    Startup="OnStartupApp"
    Exit="OnAppExit"
    DispatcherUnhandledException="OnDispatcherUnhandledException" 
  >

  <Application.Resources>
    
    <ObjectDataProvider x:Key="LVMText" ObjectType="{x:Type local:LocalizeResource}" MethodName="GetResourceTextInstance"/>
    <ObjectDataProvider x:Key="LVMMenu" ObjectType="{x:Type local:LocalizeResource}" MethodName="GetResourceMenuInstance"/>
    
    <!--<ResourceDictionary x:Key="LVMStyle">
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary   Source="ConfigurationResources/LVM.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>-->

    <Style x:Key="UsualText" TargetType="{x:Type TextBlock}">
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="Padding" Value="0,0,10,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource CenterBrush}" />
    </Style>


	</Application.Resources>

</Application>
